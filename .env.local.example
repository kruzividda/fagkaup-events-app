# Afritaðu þessa skrá í .env.local og fylltu út.
# Gildin finnurðu í Supabase: Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://DITT-VERKEFNI.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...        # "anon public" lykill
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...            # "service_role" lykill — ALDREI í vafra!

# Slóð appsins (notuð í staðfestingarpóstum og miðahlekkjum síðar)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Valfrjálst: staðfestingarpóstar (Resend). Sleppt ef ekki stillt. ---
RESEND_API_KEY=
RESEND_FROM=Fagkaup Events <events@dittlen.is>
